---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import ToggleTheme from '~/components/common/ToggleTheme.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import { getHomePermalink, trimSlash } from '~/utils/permalinks';

// 1. SHERLOCK FETCH WITH TIMEOUT PROTECTION
let links = [];
try {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), 3000);
  
  const response = await fetch('http://127.0.0.1:3000/api/globals/header', { 
    signal: controller.signal 
  });
  const headerData = await response.json();
  clearTimeout(timeoutId);

  if (headerData?.menuItems?.length > 0) {
    links = headerData.menuItems.map(item => ({
      text: item.label,
      href: item.link ? (item.link.startsWith('/') ? item.link : `/${item.link}`) : '#',
      links: item.subItems?.map(sub => ({
        text: sub.label,
        href: sub.link.startsWith('/') ? sub.link : `/${sub.link}`
      })) || []
    }));
  } else {
    throw new Error("Empty CMS Menu");
  }
} catch (e) {
  // 2. HARDCODED FALLBACK
  links = [
    { text: 'Home', href: '/' },
    { text: 'AI Services', href: '/services' },
    { text: 'Use Cases', href: '#', links: [] }, 
    { text: 'Blog', href: '/blog' },
    { text: 'Contact', href: '/contact' },
    { text: 'About Us', href: '/about' },
  ];
}

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
---

<header class="relative z-40 flex-none mx-auto w-full border-b border-gray-100/10 dark:border-slate-800/50" id="header">
  <div class="absolute inset-0"></div>
  <div class="relative text-default py-3 px-3 md:px-6 mx-auto w-full md:flex md:justify-between items-center max-w-7xl">
    
    <div class="flex justify-between md:flex-none items-center">
      <a class="flex items-center" href={getHomePermalink()}>
        <Logo />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>

    <nav class="items-center w-full md:w-auto hidden md:flex text-default overflow-y-auto overflow-x-hidden md:justify-self-center">
      <ul class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-xl md:text-[0.9375rem] tracking-[0.01rem] font-medium md:justify-center">
        {links.map(({ text, href, links: subLinks }) => (
          <li class={subLinks?.length ? 'dropdown group' : ''}>
            {subLinks?.length ? (
              <>
                <button type="button" class="hover:text-blue-600 dark:hover:text-blue-400 px-4 py-3 flex items-center whitespace-nowrap transition-colors duration-200">
                  {text} <Icon name="tabler:chevron-down" class="w-3.5 h-3.5 ml-0.5 hidden md:inline" />
                </button>
                <ul class="dropdown-menu md:backdrop-blur-md dark:md:bg-slate-900 rounded-xl md:absolute pl-4 md:pl-0 md:hidden font-medium md:bg-white/95 md:min-w-[200px] drop-shadow-2xl border border-slate-100 dark:border-slate-800">
                  {subLinks.map(({ text: text2, href: href2 }) => (
                    <li>
                      <a 
                        class:list={[
                          'py-2 px-5 block whitespace-nowrap transition-colors duration-200 bg-transparent',
                          'hover:text-blue-600 dark:hover:text-blue-400', 
                          { 'text-blue-700 dark:text-blue-300 font-bold': href2 === currentPath }
                        ]} 
                        href={href2}
                      >
                        {text2}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a 
                class:list={[
                  'hover:text-blue-600 dark:hover:text-blue-400 px-4 py-3 flex items-center whitespace-nowrap transition-colors duration-200', 
                  { 'text-blue-600 dark:text-blue-400 font-bold': href === currentPath }
                ]} 
                href={href}
              >
                {text}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="hidden md:flex items-center md:justify-end gap-4">
      <ToggleTheme iconClass="w-6 h-6 md:w-5 md:h-5" />
      
      <a 
        href="/contact" 
        class="btn-primary px-5 py-2 text-sm font-semibold rounded-full bg-blue-600 hover:bg-blue-700 text-white transition-all duration-200 shadow-lg hover:shadow-blue-500/30"
      >
        Book A Call
      </a>
    </div>
  </div>
</header>

<style is:global>
  .dropdown:hover .dropdown-menu {
    display: block;
  }
</style>